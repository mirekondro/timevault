<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.desktop.gui.HeaderController"
            maxHeight="60.0"
            minHeight="60.0"
            prefHeight="60.0"
            styleClass="app-header">
    <padding>
        <Insets top="0.0" right="22.0" bottom="0.0" left="22.0"/>
    </padding>

    <left>
        <Label fx:id="brandLabel" styleClass="header-brand" BorderPane.alignment="CENTER_LEFT"/>
    </left>

    <center>
        <HBox alignment="CENTER" spacing="10.0" styleClass="header-controls">
            <ComboBox fx:id="searchColumnComboBox" minWidth="128.0" prefWidth="128.0" styleClass="header-filter"/>
            <HBox alignment="CENTER_LEFT" maxWidth="250.0" minWidth="220.0" prefWidth="250.0"
                  spacing="0.0" styleClass="header-search-shell">
                <TextField fx:id="searchField" maxWidth="Infinity" prefWidth="0.0"
                           styleClass="header-search-field" HBox.hgrow="ALWAYS"/>
                <Button fx:id="clearSearchButton" mnemonicParsing="false" onAction="#handleClearSearch"
                        styleClass="header-clear-button" text="">
                    <graphic>
                        <Label styleClass="header-clear-icon" text="x"/>
                    </graphic>
                </Button>
            </HBox>
        </HBox>
    </center>

    <right>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="header-actions">
            <Button fx:id="avatarButton" mnemonicParsing="false" onAction="#handleUserMenuToggle"
                    styleClass="avatar-button" text="">
                <graphic>
                    <Label fx:id="avatarLetterLabel" styleClass="avatar-letter"/>
                </graphic>
            </Button>
        </HBox>
    </right>
</BorderPane>
