<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.desktop.gui.ArchiveController"
      spacing="12.0" styleClass="vault-card">
    <padding>
        <Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/>
    </padding>
    <Label styleClass="section-title" text="Archive"/>
    <Label fx:id="visibleCountLabel" styleClass="muted-copy" text="0 visible item(s)"/>
    <Separator/>
    <ListView fx:id="itemsListView" VBox.vgrow="ALWAYS"/>
</VBox>
