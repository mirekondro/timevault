<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.desktop.gui.TextDialogController"
           alignment="CENTER"
           styleClass="dialog-scene-root">
    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" vbarPolicy="AS_NEEDED">
        <content>
            <StackPane alignment="CENTER">
                <padding>
                    <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
                </padding>

                <VBox maxHeight="-Infinity" maxWidth="560.0" prefWidth="560.0" spacing="14.0" styleClass="dialog-shell">
                    <padding>
                        <Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/>
                    </padding>
                    <Label fx:id="dialogTitleLabel" styleClass="section-title"/>
                    <Label fx:id="dialogCopyLabel" styleClass="muted-copy" wrapText="true"/>
                    <Label fx:id="formMessageLabel" managed="false" styleClass="form-error-label" visible="false" wrapText="true"/>
                    <TextField fx:id="titleField" styleClass="text-field"/>
                    <Label fx:id="titleErrorLabel" managed="false" styleClass="field-error-label" visible="false" wrapText="true"/>
                    <TextArea fx:id="contentArea" prefRowCount="9" styleClass="text-area" wrapText="true"/>
                    <Label fx:id="contentErrorLabel" managed="false" styleClass="field-error-label" visible="false" wrapText="true"/>
                    <VBox spacing="10.0" styleClass="lock-box">
                        <CheckBox fx:id="lockToggle" mnemonicParsing="false" styleClass="lock-toggle"/>
                        <PasswordField fx:id="lockPasswordField" styleClass="password-field"/>
                        <Label fx:id="lockPasswordErrorLabel" managed="false" styleClass="field-error-label" visible="false" wrapText="true"/>
                        <PasswordField fx:id="confirmLockPasswordField" styleClass="password-field"/>
                        <Label fx:id="confirmLockPasswordErrorLabel" managed="false" styleClass="field-error-label" visible="false" wrapText="true"/>
                        <Label fx:id="lockHintLabel" styleClass="muted-copy" wrapText="true"/>
                    </VBox>
                    <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="dialog-actions">
                        <Button fx:id="cancelButton" cancelButton="true" mnemonicParsing="false"
                                onAction="#handleCancel" styleClass="ghost-button"/>
                        <Button fx:id="primaryButton" defaultButton="true" mnemonicParsing="false"
                                onAction="#handleSave" styleClass="accent-button"/>
                    </HBox>
                </VBox>
            </StackPane>
        </content>
    </ScrollPane>
    <fx:include fx:id="toastHostView" source="toast-host.fxml" StackPane.alignment="TOP_CENTER"/>
</StackPane>
