<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.desktop.gui.HeaderController"
            maxHeight="60.0"
            minHeight="60.0"
            prefHeight="60.0"
            styleClass="app-header">
    <padding>
        <Insets top="0.0" right="22.0" bottom="0.0" left="22.0"/>
    </padding>

    <left>
        <Label fx:id="brandLabel" styleClass="header-brand" BorderPane.alignment="CENTER_LEFT"/>
    </left>

    <center>
        <HBox alignment="CENTER" spacing="12.0" styleClass="header-controls">
            <ComboBox fx:id="searchColumnComboBox" prefWidth="150.0" styleClass="header-filter"/>
            <StackPane HBox.hgrow="ALWAYS" prefWidth="340.0" styleClass="header-search-shell">
                <TextField fx:id="searchField" maxWidth="Infinity" prefWidth="340.0"
                           styleClass="search-field header-search-field"/>
                <Button fx:id="clearSearchButton" mnemonicParsing="false" onAction="#handleClearSearch"
                        styleClass="header-clear-button" text="X" StackPane.alignment="CENTER_RIGHT"/>
            </StackPane>
            <Button fx:id="reloadButton" mnemonicParsing="false" onAction="#handleReload"
                    styleClass="ghost-button compact-button"/>
        </HBox>
    </center>

    <right>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="header-actions">
            <Button fx:id="avatarButton" mnemonicParsing="false" onAction="#handleUserMenuToggle"
                    styleClass="avatar-button" text="">
                <graphic>
                    <Label fx:id="avatarLetterLabel" styleClass="avatar-letter"/>
                </graphic>
            </Button>
        </HBox>
    </right>
</BorderPane>
