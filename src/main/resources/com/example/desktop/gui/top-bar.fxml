<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.desktop.gui.TopBarController"
      spacing="18.0">
    <HBox alignment="CENTER_LEFT" spacing="16.0">
        <VBox spacing="4.0">
            <Label styleClass="eyebrow" text="DESKTOP ARCHIVE"/>
            <Label styleClass="hero-title" text="TimeVault"/>
            <Label styleClass="muted-copy" text="Three layers: DAO, BLL, and GUI, all sharing one observable AppModel." wrapText="true"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <TextField fx:id="searchField" prefWidth="280.0" promptText="Search title, content, tags, or URL"
                       styleClass="search-field"/>
            <ComboBox fx:id="typeFilterComboBox" prefWidth="130.0" styleClass="combo-box"/>
            <Button fx:id="reloadButton" mnemonicParsing="false" onAction="#handleReload"
                    styleClass="ghost-button" text="Reload"/>
        </HBox>
    </HBox>

    <FlowPane hgap="16.0" vgap="16.0" prefWrapLength="1100.0">
        <VBox minWidth="220.0" prefWidth="240.0" spacing="6.0" styleClass="vault-card">
            <padding><Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/></padding>
            <Label styleClass="muted-copy" text="Total saved"/>
            <Label fx:id="totalCountValue" styleClass="stat-value" text="0"/>
            <Label styleClass="card-copy" text="Everything currently stored in the vault." wrapText="true"/>
        </VBox>
        <VBox minWidth="220.0" prefWidth="240.0" spacing="6.0" styleClass="vault-card">
            <padding><Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/></padding>
            <Label styleClass="muted-copy" text="URL items"/>
            <Label fx:id="urlCountValue" styleClass="stat-value" text="0"/>
            <Label styleClass="card-copy" text="Saved links and web references." wrapText="true"/>
        </VBox>
        <VBox minWidth="220.0" prefWidth="240.0" spacing="6.0" styleClass="vault-card">
            <padding><Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/></padding>
            <Label styleClass="muted-copy" text="Text items"/>
            <Label fx:id="textCountValue" styleClass="stat-value" text="0"/>
            <Label styleClass="card-copy" text="Notes, copied text, and quick captures." wrapText="true"/>
        </VBox>
        <VBox minWidth="220.0" prefWidth="240.0" spacing="6.0" styleClass="vault-card">
            <padding><Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/></padding>
            <Label styleClass="muted-copy" text="Image items"/>
            <Label fx:id="imageCountValue" styleClass="stat-value" text="0"/>
            <Label styleClass="card-copy" text="Images tracked by local file path." wrapText="true"/>
        </VBox>
    </FlowPane>
</VBox>
