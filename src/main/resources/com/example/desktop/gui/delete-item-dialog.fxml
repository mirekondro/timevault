<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.desktop.gui.DeleteItemDialogController"
           alignment="CENTER"
           styleClass="dialog-scene-root">
    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" vbarPolicy="AS_NEEDED">
        <content>
            <StackPane alignment="CENTER">
                <padding>
                    <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
                </padding>

                <VBox maxHeight="-Infinity" maxWidth="500.0" prefWidth="500.0" spacing="14.0" styleClass="dialog-shell">
                    <padding>
                        <Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/>
                    </padding>

                    <Label fx:id="dialogTitleLabel" styleClass="section-title"/>
                    <Label fx:id="dialogHeaderLabel" styleClass="status-label" wrapText="true"/>
                    <Label fx:id="dialogCopyLabel" styleClass="muted-copy" wrapText="true"/>
                    <Label fx:id="formMessageLabel" managed="false" styleClass="form-error-label" visible="false" wrapText="true"/>

                    <VBox fx:id="unlockSection" managed="false" spacing="10.0" styleClass="lock-box" visible="false">
                        <Label fx:id="unlockHelperLabel" styleClass="muted-copy" wrapText="true"/>
                        <PasswordField fx:id="unlockPasswordField" styleClass="password-field"/>
                        <Label fx:id="unlockPasswordErrorLabel" managed="false" styleClass="field-error-label" visible="false" wrapText="true"/>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="dialog-actions">
                        <Button fx:id="cancelButton" cancelButton="true" mnemonicParsing="false"
                                onAction="#handleCancel" styleClass="ghost-button"/>
                        <Button fx:id="deleteButton" mnemonicParsing="false"
                                onAction="#handleDelete" styleClass="danger-button"/>
                    </HBox>
                </VBox>
            </StackPane>
        </content>
    </ScrollPane>

    <fx:include fx:id="toastHostView" source="toast-host.fxml" StackPane.alignment="TOP_CENTER"/>
</StackPane>
